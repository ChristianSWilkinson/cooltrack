# ==========================================
# CoolTrack .gitignore
# ==========================================

# --- Data & Models (CRITICAL) ---
# Ignore all large data files and model binaries
*.parquet
*.csv
*.pkl
*.h5
*.joblib
*.model
/data/
/data_processed/

# --- Jupyter Notebooks ---
.ipynb_checkpoints/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Virtual Environments ---
venv/
env/
.venv/
conda/
miniconda/

# --- OS Generated Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# --- IDEs and Editors ---
.vscode/
.idea/
*.swp
*.swo

# --- Logs and Outputs ---
*.log
/outputs/