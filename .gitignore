# ==========================================
# CoolTrack .gitignore
# ==========================================

# --- Data & Models (CRITICAL) ---
# Globally ignore large data binaries
*.parquet
*.pkl
*.h5
*.joblib
*.model

# 1. Ignore EVERYTHING inside the data folders by default...
/data/*
/data_processed/*

# 2. ...BUT explicitly un-ignore these specific folders!
!/data/models/
!/data/age_data/

# 3. Explicitly un-ignore the file types we actually want to keep in those folders
!/data/models/*.json
!/data/age_data/*.csv

# --- Jupyter Notebooks ---
.ipynb_checkpoints/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Virtual Environments ---
venv/
env/
.venv/
conda/
miniconda/

# --- OS Generated Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# --- IDEs and Editors ---
.vscode/
.idea/
*.swp
*.swo

# --- Logs and Outputs ---
*.log
/outputs/